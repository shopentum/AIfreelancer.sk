{
  "ignoreCommand": "bash scripts/vercel-should-build-main.sh",
  "headers": [
    {
      "source": "/prusafinance/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/prusafinance/pf-contact.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/prusafinance/pf-lead.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "redirects": [
    {
      "source": "/dekujeme.html",
      "has": [{ "type": "host", "value": "aifreelancer.sk" }],
      "destination": "/prusafinance/dekujeme.html",
      "permanent": false
    },
    {
      "source": "/dekujeme.html",
      "has": [{ "type": "host", "value": "www.aifreelancer.sk" }],
      "destination": "/prusafinance/dekujeme.html",
      "permanent": false
    },
    {
      "source": "/prusafinance/:path*",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/prusafinance/:path*",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/prusafinance",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/prusafinance",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/prusafinance/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/prusafinance/index.html"
    },
    {
      "source": "/dekujeme",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/prusafinance/dekujeme.html"
    },
    {
      "source": "/dekujeme",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/prusafinance/dekujeme.html"
    },
    {
      "source": "/:page.html",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/prusafinance/:page.html"
    },
    {
      "source": "/:page.html",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/prusafinance/:page.html"
    },
    {
      "source": "/pf-contact.js",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/prusafinance/pf-contact.js"
    },
    {
      "source": "/pf-contact.js",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/prusafinance/pf-contact.js"
    },
    {
      "source": "/assets/:path*",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/prusafinance/assets/:path*"
    },
    {
      "source": "/assets/:path*",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/prusafinance/assets/:path*"
    },
    {
      "source": "/financni-gramotnost.pdf",
      "has": [{ "type": "host", "value": "prusafinance.com" }],
      "destination": "/prusafinance/financni-gramotnost.pdf"
    },
    {
      "source": "/financni-gramotnost.pdf",
      "has": [{ "type": "host", "value": "www.prusafinance.com" }],
      "destination": "/prusafinance/financni-gramotnost.pdf"
    }
  ]
}
